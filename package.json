{
    "name": "@aurora-mp/framework",
    "private": true,
    "version": "0.0.1-alpha.7",
    "description": "A cross-platform, TypeScript framework for multiplayer mods in GTA.",
    "license": "MIT",
    "author": "Aurora Team",
    "type": "module",
    "scripts": {
        "build": "turbo run build --filter=!@aurora-mp/docs",
        "build:docs": "pnpm run build && pnpm -F @aurora-mp/docs build",
        "test": "jest --verbose",
        "lint": "eslint \"packages/*/src/**/*.ts\"",
        "lint:log": "eslint \"packages/*/src/**/*.ts\" --format unix > eslint.log",
        "format": "prettier --write .",
        "release": "release-it",
        "release:dry": "release-it --dry-run --changelog"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@release-it/conventional-changelog": "^10.0.4",
        "@swc/core": "^1.15.8",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.0.3",
        "@typescript-eslint/eslint-plugin": "^8.52.0",
        "@typescript-eslint/parser": "^8.52.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-formatter-unix": "^9.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "jest": "^30.2.0",
        "prettier": "^3.7.4",
        "release-it": "^19.2.2",
        "release-it-pnpm": "^4.6.6",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsup": "^8.5.1",
        "turbo": "^2.7.3",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "reflect-metadata": "^0.2.2"
    },
    "packageManager": "pnpm@10.27.0"
}
