{
    "name": "@aurora-mp/cli",
    "version": "0.0.1-alpha.7",
    "license": "MIT",
    "author": "Aurora Team",
    "bin": {
        "aurora-mp": "./bin/index.js"
    },
    "files": [
        "bin",
        "templates",
        "theme.json"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/aurora-mp/framework.git",
        "directory": "packages/cli"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "build": "tsup && cpx \"templates/**/*\" bin/templates",
        "dev": "tsup --watch",
        "start": "node ./bin/run"
    },
    "dependencies": {
        "@oclif/core": "^4.8.0",
        "@oclif/plugin-help": "^6.2.36",
        "@oclif/plugin-not-found": "^3.2.73",
        "@oclif/plugin-update": "^4.7.16",
        "@oclif/plugin-warn-if-update-available": "^3.1.53",
        "cpx": "^1.5.0",
        "fs-extra": "^11.3.3",
        "inquirer": "^13.1.0",
        "kleur": "^4.1.5"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "tsup": "^8.5.1"
    },
    "oclif": {
        "plugins": [
            "@oclif/plugin-*"
        ],
        "theme": "theme.json",
        "bin": "aurora-mp",
        "commands": "./bin/commands"
    }
}
